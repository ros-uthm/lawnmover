<gazebo>
  <plugin
      filename="gz_ros2_control-system"
      name="gz_ros2_control::GazeboSimROS2ControlPlugin">

    <parameters>
      $(find lawnmover)/config/controllers.yaml
    </parameters>

  </plugin>
</gazebo>

</robot>
