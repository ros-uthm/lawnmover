<?xml version="1.0" ?>
<robot name="Robotic" xmlns:xacro="http://www.ros.org/wiki/xacro" >

<xacro:property name="body_color" value="Gazebo/Silver" />

<!-- Silver RGBA -->
<xacro:property name="rgba_silver"  value="0.70 0.70 0.70 1" />
<!-- Chassis green RGBA (matches RViz chassis_green) -->
<xacro:property name="rgba_green"   value="0.12 0.55 0.18 1" />
<!-- Wheel black RGBA (matches RViz wheel_black) -->
<xacro:property name="rgba_black"   value="0.06 0.06 0.06 1" />

<gazebo reference="base_link">
  <visual>
    <material>
      <ambient>${rgba_green}</ambient>
      <diffuse>${rgba_green}</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
    </material>
  </visual>
  <mu1>0.2</mu1>
  <mu2>0.2</mu2>
  <self_collide>true</self_collide>
  <gravity>true</gravity>
</gazebo>

<gazebo reference="top_body_1">
  <visual>
    <material>
      <ambient>${rgba_green}</ambient>
      <diffuse>${rgba_green}</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
    </material>
  </visual>
  <mu1>0.2</mu1>
  <mu2>0.2</mu2>
  <self_collide>true</self_collide>
</gazebo>

