<gazebo reference="rear_tyre_1">
  <visual>
    <material>
      <ambient>${rgba_black}</ambient>
      <diffuse>${rgba_black}</diffuse>
      <specular>0.05 0.05 0.05 1</specular>
    </material>
  </visual>
  <mu1>1.2</mu1>
  <mu2>1.2</mu2>
  <self_collide>true</self_collide>
  <surface>
    <contact>
      <ode>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <min_depth>0.001</min_depth>
        <max_vel>0.0</max_vel>
      </ode>
    </contact>
    <friction>
      <ode>
        <slip1>0.0</slip1>
        <slip2>0.0</slip2>
      </ode>
    </friction>
  </surface>
</gazebo>

<gazebo reference="rear_tyre_2">
  <visual>
    <material>
      <ambient>${rgba_black}</ambient>
      <diffuse>${rgba_black}</diffuse>
